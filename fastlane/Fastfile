# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"

default_platform(:ios)

platform :ios do

  lane :release_testflight do |options|
    # Setup the keychain and match to work with CI
    setup_ci

    # All config via ENV vars (set by workflow)
    app_identifier = ENV['BUNDLE_ID']
    xcode_project = ENV['XCODE_PROJECT_PATH']
    xcworkspace = ENV['XCWORKSPACE_PATH']
    app_description = ENV['APP_DESCRIPTION'] || 'Sample app'

    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_KEY_ID'],
      issuer_id: ENV['APPLE_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_KEY'],
      duration: 1200,
      in_house: false,
    )

    match(
      readonly: false,
      type: "appstore",
      app_identifier: app_identifier,
      git_url: ENV['MATCH_GIT_URL'],
      api_key: api_key,
      include_all_certificates: true,
      force_for_new_devices: true,
      force_for_new_certificates: true,
      verbose: true,
    )

    _flavor = options[:flavor]
    _app_version = options[:app_version]

    # Get latest build number from TestFlight (across all versions).
    number = latest_testflight_build_number(
      app_identifier: app_identifier,
    )
    new_build_number = number.to_i + 1
    UI.message(
      "📦 Latest TestFlight build number: #{number} " \
      "→ new build number: #{new_build_number}"
    )

    # Set build number in the Xcode project (modifies CURRENT_PROJECT_VERSION)
    increment_build_number(
      build_number: new_build_number,
      xcodeproj: xcode_project,
    )

    gym(
      configuration: "Release-#{_flavor}",
      workspace: xcworkspace,
      scheme: _flavor,
      export_method: "app-store",
      clean: true,
      xcargs: "PROJECT_ID='#{options[:project_id]}'",
      output_directory: "build",
      include_symbols: false,
    )

    # Remove macOS hidden files from archive
    # Note: sh() runs from fastlane/ directory, so use ../ to reach repo root
    sh('''
      IPA_PATH="../build/Runner.ipa"

      if [ -f "$IPA_PATH" ]; then
        echo "Checking for unwanted files like ._Symbols in $IPA_PATH"
        unzip -l "$IPA_PATH" | grep ._Symbols && zip -d "$IPA_PATH" ._Symbols/ || echo "No ._Symbols found"
      else
        echo "IPA not found at $IPA_PATH"
      fi
    ''')

    # Get release notes from ENV (set by workflow, defaults to branch name)
    changelog = ENV['RELEASE_NOTES'] || 'New release'

    upload_to_testflight(
      apple_id: ENV['APPLE_APP_ID'],
      app_version: _app_version,
      build_number: new_build_number.to_s,
      app_identifier: app_identifier,
      changelog: changelog,
      distribute_external: true,
      notify_external_testers: true,
      skip_waiting_for_build_processing: false,
      beta_app_feedback_email: "alfredo@reown.com",
      beta_app_description: app_description,
      groups: ["External Testers"]
    )

    clean_build_artifacts()
  end

end
