<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen configuration -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">#202020</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/walletconnect_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#202020</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
